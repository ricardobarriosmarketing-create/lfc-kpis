/* -----------------------------
  Helpers (formato / cálculos)
------------------------------ */
const clamp = (v, min, max) => Math.min(max, Math.max(min, v));
const formatInt = (n) => new Intl.NumberFormat("es-ES").format(Math.round(n));
const formatMoney = (n) =>
  new Intl.NumberFormat("es-ES", {
    style: "currency",
    currency: "USD",
    maximumFractionDigits: 0,
  }).format(Math.round(n));

const formatPct = (v) =>
  new Intl.NumberFormat("es-ES", {
    style: "percent",
    maximumFractionDigits: 0,
  }).format(v);

function cn(...classes) {
  return classes.filter(Boolean).join(" ");
}

/* -----------------------------
  Simulación de datos ClickUp
  Basado en 80 tareas mensuales
  Estados: Grabación, Por Revisión,
  Listos por calendarizar,
  Tarjetas Completadas
------------------------------ */
const STATUSES = [
  { key: "grabacion", label: "Grabación", color: "#22d3ee" }, // cyan
  { key: "revision", label: "Por Revisión", color: "#fbbf24" }, // amber
  { key: "listos", label: "Listos por calendarizar", color: "#a78bfa" }, // violet
  { key: "completadas", label: "Tarjetas Completadas", color: "#34d399" }, // green
];

// Distribución razonable para argumentar inversión (capacidad alta, con cuello visible)
function simulateClickUpCounts(total = 80) {
  // Intención: demostrar throughput (muchas completadas/listas), pero también alertar el cuello de revisión.
  // Ajusta si quieres otro "storytelling".
  const grabacion = 18;
  const revision = 15; // cuello de botella explícito para alertas
  const listos = 17;
  const completadas = total - grabacion - revision - listos; // 30
  return { total, grabacion, revision, listos, completadas };
}

/* -----------------------------
  Simulación de serie semanal:
  Marketing (tareas completadas/listas)
  vs Ventas/Leads
  (correlación positiva)
------------------------------ */
function buildWeeklySeries({
  weeks = 4,
  completedTotal,
  readyTotal,
  baselineLeads = 320,
}) {
  // Distribuir completadas y listos en 4 semanas con crecimiento
  const dist = [0.20, 0.24, 0.26, 0.30]; // más producción hacia fin de mes
  const data = [];

  let completedAcc = 0;
  let readyAcc = 0;

  for (let i = 0; i < weeks; i++) {
    const w = i + 1;

    const completed = Math.round(completedTotal * dist[i]);
    const ready = Math.round(readyTotal * dist[i]);

    completedAcc += completed;
    readyAcc += ready;

    // Señal de marketing: “supply” real para Ads (listos + completados)
    const marketingSupply = completed + ready;

    // Leads: baseline + efecto incremental por supply (correlación).
    // Nota: esto es un modelo simplificado para justificar inversión.
    const incrementalLeads =
      marketingSupply * 9 + // cada pieza lista/completada habilita más creatividad/variantes
      completed * 4; // completadas tienden a ser "probadas" y optimizadas

    const leads = Math.round(baselineLeads / weeks + incrementalLeads);

    // Ventas aproximadas: conversión a venta (ej: 6% de leads)
    const sales = Math.round(leads * 0.06);

    data.push({
      week: `Semana ${w}`,
      completed,
      ready,
      marketingSupply,
      leads,
      sales,
      // Punto de dispersión para ver relación supply -> leads
      xSupply: marketingSupply,
      yLeads: leads,
    });
  }

  // Ajuste pequeño para que cuadre al total (si los redondeos descuadran)
  // Se corrige en la última semana.
  const completedSum = data.reduce((s, d) => s + d.completed, 0);
  const readySum = data.reduce((s, d) => s + d.ready, 0);
  data[data.length - 1].completed += completedTotal - completedSum;
  data[data.length - 1].ready += readyTotal - readySum;
  data[data.length - 1].marketingSupply =
    data[data.length - 1].completed + data[data.length - 1].ready;

  return data;
}

/* -----------------------------
  Modelo ROI (Simulador Ads)
  Presupuesto -> leads -> ventas -> revenue -> ROI

  Idea PM/CMO:
    - Capacidad de contenido (listos/completadas) habilita escalamiento.
    - Eficiencia marginal decreciente (saturación).
    - “Contenido disponible” limita el rendimiento si intentas escalar sin supply.
------------------------------ */
function projectROI({
  budget,
  readyToRun, // contenido que puede pautarse ya
  avgOrderValue = 250, // ticket promedio
  closeRate = 0.055, // leads -> ventas
  cplBase = 7.5, // costo por lead base (con presupuesto moderado)
}) {
  // Capacidad: cada pieza lista/completada puede "soportar" un número de leads sin fatiga creativa.
  const leadsCapacity = readyToRun * 120; // capacidad por mes (ajustable)

  // Eficiencia: con más presupuesto, el CPL sube (diminishing returns).
  // Usamos una curva suave: cpl = cplBase * (1 + (budget / 20000)^0.55)
  const cpl = cplBase * (1 + Math.pow(budget / 20000, 0.55));

  // Leads teóricos por presupuesto
  const leadsByBudget = budget / cpl;

  // Leads reales limitados por capacidad de contenido
  const leads = Math.round(Math.min(leadsByBudget, leadsCapacity));

  const sales = Math.round(leads * closeRate);
  const revenue = sales * avgOrderValue;

  const roi = budget > 0 ? (revenue - budget) / budget : 0;

  return {
    budget,
    cpl,
    leads,
    sales,
    revenue,
    roi,
    constrained: leadsByBudget > leadsCapacity,
    leadsCapacity,
  };
}

/* -----------------------------
  Componentes UI simples
------------------------------ */
function KpiCard({
  icon: Icon,
  title,
  value,
  sub,
  accent = "from-cyan-500/25 via-purple-500/20 to-pink-500/20",
  statusDot,
  rightTag,
}) {
  return (
    <div className="relative overflow-hidden rounded-2xl border border-white/10 bg-slate-950/40 p-5 shadow-[0_0_0_1px_rgba(255,255,255,0.06)_inset]">
      <div className={cn("pointer-events-none absolute inset-0 bg-gradient-to-br", accent)} />
      <div className="relative flex items-start justify-between gap-4">
        <div className="flex items-start gap-3">
          <div className="rounded-xl border border-white/10 bg-white/5 p-2">
            <Icon className="h-5 w-5 text-white/90" />
          </div>
          <div>
            <div className="flex items-center gap-2">
              <p className="text-sm text-white/70">{title}</p>
              {statusDot && (
                <span className="inline-flex items-center gap-1 rounded-full border border-white/10 bg-black/30 px-2 py-0.5 text-xs text-white/70">
                  <CircleDot
                    className={cn(
                      "h-3 w-3",
                      statusDot === "green" && "text-emerald-400",
                      statusDot === "yellow" && "text-amber-300",
                      statusDot === "red" && "text-rose-400"
                    )}
                  />
                  {rightTag}
                </span>
              )}
            </div>
            <p className="mt-1 text-2xl font-semibold tracking-tight text-white">{value}</p>
            {sub && <p className="mt-1 text-xs text-white/60">{sub}</p>}
          </div>
        </div>

        <div className="flex items-center gap-2">
          {rightTag && !statusDot && (
            <span className="rounded-full border border-white/10 bg-black/30 px-3 py-1 text-xs text-white/70">
              {rightTag}
            </span>
          )}
        </div>
      </div>
    </div>
  );
}

function SectionCard({ title, icon: Icon, children, hint }) {
  return (
    <div className="rounded-2xl border border-white/10 bg-slate-950/40 p-5 shadow-[0_0_0_1px_rgba(255,255,255,0.06)_inset]">
      <div className="mb-4 flex items-start justify-between gap-3">
        <div className="flex items-center gap-2">
          {Icon && (
            <div className="rounded-xl border border-white/10 bg-white/5 p-2">
              <Icon className="h-5 w-5 text-white/90" />
            </div>
          )}
          <div>
            <h2 className="text-base font-semibold text-white">{title}</h2>
            {hint && <p className="mt-0.5 text-xs text-white/60">{hint}</p>}
          </div>
        </div>
      </div>
      {children}
    </div>
  );
}

function AlertPill({ level = "warning", title, desc }) {
  const styles =
    level === "danger"
      ? "border-rose-500/30 bg-rose-500/10 text-rose-200"
      : level === "success"
      ? "border-emerald-500/30 bg-emerald-500/10 text-emerald-200"
      : "border-amber-500/30 bg-amber-500/10 text-amber-100";

  const Icon =
    level === "danger" ? AlertTriangle : level === "success" ? CheckCircle2 : Timer;

  return (
    <div className={cn("rounded-2xl border p-4", styles)}>
      <div className="flex items-start gap-3">
        <Icon className="mt-0.5 h-5 w--5" />
        <div>
          <p className="text-sm font-semibold">{title}</p>
          {desc && <p className="mt-1 text-xs opacity-90">{desc}</p>}
        </div>
      </div>
    </div>
  );
}

/* -----------------------------
  Tooltip custom Recharts
------------------------------ */
function DarkTooltip({ active, payload, label }) {
  if (!active || !payload?.length) return null;

  return (
    <div className="rounded-xl border border-white/10 bg-slate-950/95 p-3 text-xs text-white shadow-xl">
      <p className="mb-2 text-white/70">{label}</p>
      <div className="space-y-1">
        {payload.map((p, idx) => (
          <div key={idx} className="flex items-center justify-between gap-6">
            <span className="flex items-center gap-2">
              <span className="inline-block h-2 w-2 rounded-full" style={{ background: p.color }} />
              <span className="text-white/80">{p.name}</span>
            </span>
            <span className="font-semibold text-white">
              {typeof p.value === "number" ? formatInt(p.value) : String(p.value)}
            </span>
          </div>
        ))}
      </div>
    </div>
  );
}

/* -----------------------------
  App
------------------------------ */
export default function App() {
  const clickUp = useMemo(() => simulateClickUpCounts(80), []);
  const { total, grabacion, revision, listos, completadas } = clickUp;

  // KPI: productividad
  const productivity = completadas / total; // completadas vs total
  const readyToRun = listos + completadas; // capacidad real para pauta (lista + completada)

  // Semáforo tablero (estado operativo del embudo)
  // Lógica CMO/PM: revisión alta es riesgo; listos+completadas alto es capacidad.
  const boardStatus = useMemo(() => {
    const reviewPressure = revision / total;
    const supplyRatio = readyToRun / total;

    if (reviewPressure >= 0.22) return { dot: "red", label: "Riesgo (Revisión)" };
    if (supplyRatio >= 0.55) return { dot: "green", label: "Saludable" };
    return { dot: "yellow", label: "Atención" };
  }, [revision, total, readyToRun]);

  const funnelData = useMemo(
    () => [
      { name: "Grabación", value: grabacion, fill: STATUSES[0].color },
      { name: "Por Revisión", value: revision, fill: STATUSES[1].color },
      { name: "Listos", value: listos, fill: STATUSES[2].color },
      { name: "Completadas", value: completadas, fill: STATUSES[3].color },
    ],
    [grabacion, revision, listos, completadas]
  );

  const weekly = useMemo(
    () =>
      buildWeeklySeries({
        weeks: 4,
        completedTotal: completadas,
        readyTotal: listos,
        baselineLeads: 320,
      }),
    [completadas, listos]
  );

  // Simulador Ads
  const [budget, setBudget] = useState(18000);
  const roi = useMemo(
    () =>
      projectROI({
        budget,
        readyToRun,
        avgOrderValue: 250,
        closeRate: 0.055,
        cplBase: 7.5,
      }),
    [budget, readyToRun]
  );

  // Presupuesto recomendado (orientado a justificar inversión)
  // Si hay capacidad de contenido alta, recomendamos un budget agresivo.
  const proposedBudget = useMemo(() => {
    const base = 15000;
    const capacityBoost = (readyToRun / 80) * 20000; // a más supply, más techo de inversión
    return clamp(Math.round(base + capacityBoost), 14000, 42000);
  }, [readyToRun]);

  // Alertas automáticas y cuellos de botella
  const alerts = useMemo(() => {
    const items = [];

    if (revision >= 15) {
      items.push({
        level: "danger",
        title: `Alerta: ${revision} tarjetas estancadas en "Por Revisión"`,
        desc:
          "Riesgo directo para escalar Ads: sin aprobación, el contenido no llega a 'Listos'. Prioriza revisiones, define SLA y reduce re-trabajo.",
      });
    } else if (revision >= 10) {
      items.push({
        level: "warning",
        title: `Atención: ${revision} tarjetas en "Por Revisión"`,
        desc:
          "Recomendación: bloque diario de revisión, checklist de calidad y plantilla de feedback para acelerar throughput.",
      });
    } else {
      items.push({
        level: "success",
        title: "Revisión bajo control",
        desc: "La cola de revisión está saludable, buen momento para aumentar inversión y testeo creativo.",
      });
    }

    if (grabacion >= 22) {
      items.push({
        level: "warning",
        title: `Señal: ${grabacion} tarjetas en "Grabación"`,
        desc:
          "Hay mucho trabajo en producción. Si el ritmo no baja, podría impactar la velocidad de salida a pauta.",
      });
    }

    if (readyToRun >= 40) {
      items.push({
        level: "success",
        title: `Capacidad alta: ${readyToRun} piezas listas para pauta (Listos + Completadas)`,
        desc:
          "Argumento fuerte para invertir: hay suficiente inventario creativo para sostener pruebas A/B y expansión de audiencias.",
      });
    } else if (readyToRun < 28) {
      items.push({
        level: "danger",
        title: `Inventario creativo limitado: ${readyToRun} piezas listas para pauta`,
        desc:
          "Antes de escalar Ads, aumenta el throughput hacia 'Listos' o el rendimiento caerá por fatiga creativa.",
      });
    }

    return items;
  }, [revision, grabacion, readyToRun]);

  // Texto ejecutivo de justificación (para CMO)
  const investmentNarrative = useMemo(() => {
    const supplyMsg =
      readyToRun >= 40
        ? "inventario creativo robusto"
        : readyToRun >= 30
        ? "inventario creativo suficiente, con margen de mejora"
        : "inventario creativo bajo, requiere acelerar producción";

    const riskMsg =
      boardStatus.dot === "red"
        ? "Hay riesgo operativo en revisión que puede frenar la escalabilidad."
        : boardStatus.dot === "yellow"
        ? "Hay señales de fricción, pero aún es escalable con gestión diaria."
        : "Operación saludable, escalabilidad lista para el próximo mes.";

    return `Tenemos ${supplyMsg} para sostener campañas y variaciones creativas; ${riskMsg}`;
  }, [readyToRun, boardStatus.dot]);

  return (
    <div className="min-h-screen bg-[#070A12] text-white">
      {/* Background glow */}
      <div className="pointer-events-none fixed inset-0 overflow-hidden">
        <div className="absolute -top-40 left-1/2 h-[520px] w-[520px] -translate-x-1/2 rounded-full bg-fuchsia-500/15 blur-[120px]" />
        <div className="absolute top-48 -left-24 h-[520px] w-[520px] rounded-full bg-cyan-500/15 blur-[120px]" />
        <div className="absolute bottom-0 right-0 h-[520px] w-[520px] rounded-full bg-violet-500/15 blur-[120px]" />
      </div>

      <div className="relative mx-auto max-w-7xl px-6 py-8">
        {/* Header */}
        <div className="mb-6 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <div className="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-white/70">
              <LayoutDashboard className="h-4 w-4 text-white/80" />
              Dashboard Marketing, ClickUp "Abril Contenido"
            </div>
            <h1 className="mt-3 text-2xl font-semibold tracking-tight">
              Panel Interactivo para justificar inversión fuerte en Ads (próximo mes)
            </h1>
            <p className="mt-2 max-w-2xl text-sm text-white/65">
              Enfoque PM + CMO: visibiliza capacidad de producción (ClickUp funnel),
              detecta cuellos de botella y proyecta ROI al escalar presupuesto.
            </p>
          </div>

          <div className="rounded-2xl border border-white/10 bg-slate-950/40 p-4">
            <div className="flex items-center gap-3">
              <div className="rounded-xl border border-white/10 bg-white/5 p-2">
                <Sparkles className="h-5 w-5 text-fuchsia-300" />
              </div>
              <div>
                <p className="text-xs text-white/60">Lectura ejecutiva</p>
                <p className="text-sm font-semibold text-white">{investmentNarrative}</p>
              </div>
            </div>
          </div>
        </div>

        {/* KPI Cards */}
        <div className="grid grid-cols-1 gap-4 md:grid-cols-3">
          <KpiCard
            icon={TrendingUp}
            title="Tasa de productividad"
            value={`${formatPct(productivity)} (${completadas}/${total})`}
            sub="Tarjetas completadas vs total mensual (simulación 80 tareas)"
            accent="from-emerald-500/20 via-cyan-500/15 to-violet-500/15"
            rightTag={readyToRun >= 40 ? "Capacidad alta" : "Capacidad en progreso"}
          />

          <KpiCard
            icon={BadgeDollarSign}
            title="Presupuesto Ads propuesto (próximo mes)"
            value={formatMoney(proposedBudget)}
            sub={`Basado en inventario creativo listo para pauta (${readyToRun} piezas) y proyección de escalabilidad.`}
            accent="from-fuchsia-500/25 via-purple-500/20 to-cyan-500/10"
            rightTag="Propuesta"
          />

          <KpiCard
            icon={Activity}
            title='Semáforo del tablero (ClickUp "Abril Contenido")'
            value={boardStatus.label}
            sub='Señal operativa en base a presión de "Por Revisión" y supply listo.'
            accent="from-amber-500/20 via-rose-500/10 to-violet-500/15"
            statusDot={boardStatus.dot}
            rightTag={boardStatus.label}
          />
        </div>

        {/* Main grid */}
        <div className="mt-6 grid grid-cols-1 gap-4 lg:grid-cols-3">
          {/* Funnel */}
          <div className="lg:col-span-2">
            <SectionCard
              title="Embudo de Producción (ClickUp)"
              icon={Target}
              hint='Grabación → Por Revisión → Listos por calendarizar → Tarjetas Completadas'
            >
              <div className="mb-4 grid grid-cols-2 gap-3 sm:grid-cols-4">
                {STATUSES.map((s) => {
                  const val =
                    s.key === "grabacion"
                      ? grabacion
                      : s.key === "revision"
                      ? revision
                      : s.key === "listos"
                      ? listos
                      : completadas;
                  return (
                    <div
                      key={s.key}
                      className="rounded-2xl border border-white/10 bg-black/20 p-3"
                    >
                      <div className="flex items-center justify-between gap-2">
                        <p className="text-xs text-white/70">{s.label}</p>
                        <span
                          className="h-2.5 w-2.5 rounded-full"
                          style={{ background: s.color }}
                        />
                      </div>
                      <p className="mt-2 text-xl font-semibold">{formatInt(val)}</p>
                      <p className="mt-1 text-xs text-white/50">{formatPct(val / total)} del total</p>
                    </div>
                  );
                })}
              </div>

              <div className="h-[300px] w-full">
                <ResponsiveContainer width="100%" height="100%">
                  <BarChart data={funnelData} barCategoryGap={22}>
                    <CartesianGrid stroke="rgba(255,255,255,0.07)" strokeDasharray="3 3" />
                    <XAxis
                      dataKey="name"
                      tick={{ fill: "rgba(255,255,255,0.7)", fontSize: 12 }}
                      axisLine={{ stroke: "rgba(255,255,255,0.12)" }}
                      tickLine={{ stroke: "rgba(255,255,255,0.12)" }}
                    />
                    <YAxis
                      tick={{ fill: "rgba(255,255,255,0.6)", fontSize: 12 }}
                      axisLine={{ stroke: "rgba(255,255,255,0.12)" }}
                      tickLine={{ stroke: "rgba(255,255,255,0.12)" }}
                      allowDecimals={false}
                    />
                    <Tooltip content={<DarkTooltip />} />
                    <Legend wrapperStyle={{ color: "rgba(255,255,255,0.65)", fontSize: 12 }} />
                    <Bar dataKey="value" name="Tarjetas" radius={[10, 10, 10, 10]}>
                      {funnelData.map((entry, index) => (
                        <cell key={`cell-${index}`} fill={entry.fill} />
                      ))}
                    </Bar>
                  </BarChart>
                </ResponsiveContainer>
              </div>

              <div className="mt-4 rounded-2xl border border-white/10 bg-black/20 p-4">
                <p className="text-sm font-semibold text-white">Lectura para inversión</p>
                <p className="mt-1 text-sm text-white/65">
                  El objetivo de Ads es escalar con seguridad. Aquí, el indicador clave es{" "}
                  <span className="font-semibold text-white">contenido listo para pauta ({readyToRun})</span>
                  . A mayor inventario, más tests creativos, mejor aprendizaje y más volumen
                  sin fatiga.
                </p>
              </div>
            </SectionCard>
          </div>

          {/* Alerts */}
          <div className="lg:col-span-1">
            <SectionCard
              title="Alertas y cuellos de botella"
              icon={AlertTriangle}
              hint="Reglas automáticas (simuladas) para acelerar throughput"
            >
              <div className="space-y-3">
                {alerts.map((a, idx) => (
                  <AlertPill key={idx} level={a.level} title={a.title} desc={a.desc} />
                ))}
              </div>

              <div className="mt-4 rounded-2xl border border-white/10 bg-black/20 p-4">
                <p className="text-xs text-white/60">Recomendación PM rápida:</p>
                <ul className="mt-2 list-disc space-y-1 pl-4 text-xs text-white/65">
                  <li>Define SLA de revisión (ej: 24h) y un “revisor dueño” por día.</li>
                  <li>Checklist de criterios de “Listo” para reducir iteraciones.</li>
                  <li>Bloques diarios de 30-45 min para limpiar cola de revisión.</li>
                </ul>
              </div>
            </SectionCard>
          </div>
        </div>

        {/* Correlación Ventas vs Marketing */}
        <div className="mt-4 grid grid-cols-1 gap-4 lg:grid-cols-3">
          <div className="lg:col-span-2">
            <SectionCard
              title="Correlación Marketing (output) vs Ventas/Leads"
              icon={ArrowUpRight}
              hint="Modelo combinado: supply de contenido (listos+completados) impulsa leads y ventas"
            >
              <div className="h-[320px] w-full">
                <ResponsiveContainer width="100%" height="100%">
                  <ComposedChart data={weekly}>
                    <CartesianGrid stroke="rgba(255,255,255,0.07)" strokeDasharray="3 3" />
                    <XAxis
                      dataKey="week"
                      tick={{ fill: "rgba(255,255,255,0.7)", fontSize: 12 }}
                      axisLine={{ stroke: "rgba(255,255,255,0.12)" }}
                      tickLine={{ stroke: "rgba(255,255,255,0.12)" }}
                    />
                    <YAxis
                      yAxisId="left"
                      tick={{ fill: "rgba(255,255,255,0.6)", fontSize: 12 }}
                      axisLine={{ stroke: "rgba(255,255,255,0.12)" }}
                      tickLine={{ stroke: "rgba(255,255,255,0.12)" }}
                      allowDecimals={false}
                    />
                    <YAxis
                      yAxisId="right"
                      orientation="right"
                      tick={{ fill: "rgba(255,255,255,0.6)", fontSize: 12 }}
                      axisLine={{ stroke: "rgba(255,255,255,0.12)" }}
                      tickLine={{ stroke: "rgba(255,255,255,0.12)" }}
                      allowDecimals={false}
                    />
                    <Tooltip content={<DarkTooltip />} />
                    <Legend wrapperStyle={{ color: "rgba(255,255,255,0.65)", fontSize: 12 }} />

                    <Area
                      yAxisId="left"
                      type="monotone"
                      dataKey="marketingSupply"
                      name="Supply (Listos+Completadas)"
                      stroke="#a78bfa"
                      fill="#a78bfa"
                      fillOpacity={0.15}
                    />

                    <Line
                      yAxisId="right"
                      type="monotone"
                      dataKey="leads"
                      name="Leads"
                      stroke="#22d3ee"
                      strokeWidth={2}
                      dot={{ r: 3 }}
                    />

                    <Line
                      yAxisId="right"
                      type="monotone"
                      dataKey="sales"
                      name="Ventas"
                      stroke="#34d399"
                      strokeWidth={2}
                      dot={{ r: 3 }}
                    />

                    <ReferenceLine
                      yAxisId="left"
                      y={Math.round((readyToRun / 4) * 0.9)}
                      stroke="rgba(255,255,255,0.18)"
                      strokeDasharray="4 4"
                      label={{ value: "Umbral supply", fill: "rgba(255,255,255,0.55)", fontSize: 11 }}
                    />
                  </ComposedChart>
                </ResponsiveContainer>
              </div>

              <div className="mt-4 grid grid-cols-1 gap-3 md:grid-cols-3">
                <div className="rounded-2xl border border-white/10 bg-black/20 p-4">
                  <p className="text-xs text-white/60">Idea clave</p>
                  <p className="mt-1 text-sm font-semibold">Más supply = más aprendizaje</p>
                  <p className="mt-1 text-xs text-white/65">
                    Al aumentar volumen creativo, aceleras tests A/B y optimización.
                  </p>
                </div>
                <div className="rounded-2xl border border-white/10 bg-black/20 p-4">
                  <p className="text-xs text-white/60">PM lens</p>
                  <p className="mt-1 text-sm font-semibold">La revisión es el “gate”</p>
                  <p className="mt-1 text-xs text-white/65">
                    Si la cola crece, se rompe el flujo hacia Ads.
                  </p>
                </div>
                <div className="rounded-2xl border border-white/10 bg-black/20 p-4">
                  <p className="text-xs text-white/60">CMO lens</p>
                  <p className="mt-1 text-sm font-semibold">Escala con control</p>
                  <p className="mt-1 text-xs text-white/65">
                    El presupuesto debe seguir capacidad real, no intención.
                  </p>
                </div>
              </div>
            </SectionCard>
          </div>

          {/* Scatter mini: correlación supply vs leads */}
          <div className="lg:col-span-1">
            <SectionCard title="Relación supply → leads" icon={TrendingUp} hint="Dispersión semanal (simulada)">
              <div className="h-[320px] w-full">
                <ResponsiveContainer width="100%" height="100%">
                  <ComposedChart data={weekly}>
                    <CartesianGrid stroke="rgba(255,255,255,0.07)" strokeDasharray="3 3" />
                    <XAxis
                      dataKey="xSupply"
                      type="number"
                      name="Supply"
                      tick={{ fill: "rgba(255,255,255,0.7)", fontSize: 12 }}
                      axisLine={{ stroke: "rgba(255,255,255,0.12)" }}
                      tickLine={{ stroke: "rgba(255,255,255,0.12)" }}
                    />
                    <YAxis
                      dataKey="yLeads"
                      type="number"
                      name="Leads"
                      tick={{ fill: "rgba(255,255,255,0.6)", fontSize: 12 }}
                      axisLine={{ stroke: "rgba(255,255,255,0.12)" }}
                      tickLine={{ stroke: "rgba(255,255,255,0.12)" }}
                      allowDecimals={false}
                    />
                    <Tooltip content={<DarkTooltip />} />
                    <Legend wrapperStyle={{ color: "rgba(255,255,255,0.65)", fontSize: 12 }} />
                    <Scatter dataKey="yLeads" name="Leads vs Supply" fill="#22d3ee" />
                    <Line type="monotone" dataKey="yLeads" name="Tendencia (visual)" stroke="#a78bfa" strokeWidth={2} dot={false} />
                  </ComposedChart>
                </ResponsiveContainer>
              </div>

              <div className="mt-4 rounded-2xl border border-white/10 bg-black/20 p-4">
                <p className="text-xs text-white/60">Lectura</p>
                <p className="mt-1 text-xs text-white/70">
                  Cuando el supply semanal sube, los leads suben. Este es el puente
                  narrativo entre ClickUp (producción) y Ads (ingresos).
                </p>
              </div>
            </SectionCard>
          </div>
        </div>

        {/* Simulador presupuesto */}
        <div className="mt-4">
          <SectionCard
            title="Simulador de Presupuesto (Ads) y ROI proyectado"
            icon={SlidersHorizontal}
            hint="Mueve el presupuesto y observa leads, ventas, revenue y ROI, limitado por contenido listo"
          >
            <div className="grid grid-cols-1 gap-4 lg:grid-cols-3">
              <div className="lg:col-span-1 rounded-2xl border border-white/10 bg-black/20 p-5">
                <div className="flex items-center justify-between">
                  <p className="text-sm font-semibold text-white">Presupuesto mensual</p>
                  <span className="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-white/70">
                    {formatMoney(budget)}
                  </span>
                </div>

                <div className="mt-4">
                  <input
                    type="range"
                    min={5000}
                    max={50000}
                    step={500}
                    value={budget}
                    onChange={(e) => setBudget(Number(e.target.value))}
                    className="w-full accent-fuchsia-400"
                  />
                  <div className="mt-2 flex items-center justify-between text-xs text-white/55">
                    <span>{formatMoney(5000)}</span>
                    <span>{formatMoney(50000)}</span>
                  </div>
                </div>

                <div className="mt-5 space-y-3">
                  <div className="flex items-center justify-between rounded-xl border border-white/10 bg-white/5 px-3 py-2">
                    <span className="text-xs text-white/70">Contenido listo</span>
                    <span className="text-xs font-semibold">{formatInt(readyToRun)}</span>
                  </div>
                  <div className="flex items-center justify-between rounded-xl border border-white/10 bg-white/5 px-3 py-2">
                    <span className="text-xs text-white/70">Capacidad leads (por contenido)</span>
                    <span className="text-xs font-semibold">{formatInt(roi.leadsCapacity)}</span>
                  </div>
                </div>

                <div className="mt-4">
                  {roi.constrained ? (
                    <AlertPill
                      level="warning"
                      title="Limitado por inventario creativo"
                      desc="Puedes subir presupuesto, pero el rendimiento se frena por falta de contenido listo. Mejora throughput hacia 'Listos'."
                    />
                  ) : (
                    <AlertPill
                      level="success"
                      title="Escala soportada por contenido"
                      desc="El presupuesto está dentro del límite operativo de contenido listo para pautar."
                    />
                  )}
                </div>
              </div>

              <div className="lg:col-span-2 rounded-2xl border border-white/10 bg-black/20 p-5">
                <div className="grid grid-cols-1 gap-3 md:grid-cols-4">
                  <div className="rounded-2xl border border-white/10 bg-slate-950/40 p-4">
                    <p className="text-xs text-white/60">CPL estimado</p>
                    <p className="mt-1 text-lg font-semibold">{formatMoney(roi.cpl)}</p>
                    <p className="mt-1 text-xs text-white/55">Subida por saturación al aumentar gasto</p>
                  </div>
                  <div className="rounded--2xl border border-white/10 bg-slate-950/40 p-4">
                    <p className="text-xs text-white/60">Leads</p>
                    <p className="mt-1 text-lg font-semibold">{formatInt(roi.leads)}</p>
                    <p className="mt-1 text-xs text-white/55">Limitado por contenido si aplica</p>
                  </div>
                  <div className="rounded-2xl border border-white/10 bg-slate-950/40 p-4">
                    <p className="text-xs text-white/60">Ventas</p>
                    <p className="mt-1 text-lg font-semibold">{formatInt(roi.sales)}</p>
                    <p className="mt-1 text-xs text-white/55">close rate simulado</p>
                  </div>
                  <div className="rounded-2xl border border-white/10 bg-slate-950/40 p-4">
                    <p className="text-xs text-white/60">Revenue</p>
                    <p className="mt-1 text-lg font-semibold">{formatMoney(roi.revenue)}</p>
                    <p className="mt-1 text-xs text-white/55">ticket promedio simulado</p>
                  </div>
                </div>

                <div className="mt-4 rounded-2xl border border-white/10 bg-slate-950/40 p-4">
                  <div className="flex items-center justify-between gap-3">
                    <div className="flex items-center gap-2">
                      <div className="rounded-xl border border-white/10 bg-white/5 p-2">
                        <BadgeDollarSign className="h-5 w-5 text-emerald-300" />
                      </div>
                      <div>
                        <p className="text-xs text-white/60">ROI proyectado</p>
                        <p
                          className={cn(
                            "text-xl font-semibold",
                            roi.roi >= 0.4
                              ? "text-emerald-300"
                              : roi.roi >= 0.15
                              ? "text-amber-200"
                              : "text-rose-300"
                          )}
                        >
                          {formatPct(roi.roi)}
                        </p>
                      </div>
                    </div>

                    <div className="rounded-full border border-white/10 bg-black/30 px-3 py-1 text-xs text-white/70">
                      {roi.roi >= 0.4
                        ? "Caso fuerte para inversión"
                        : roi.roi >= 0.15
                        ? "Caso razonable, optimiza creatives"
                        : "Requiere ajustes (CPL o conversión)"}
                    </div>
                  </div>

                  <div className="mt-3 grid grid-cols-1 gap-2 md:grid-cols-2">
                    <div className="rounded-xl border border-white/10 bg-black/20 p-3">
                      <p className="text-xs font-semibold text-white/80">
                        Palanca 1: aumentar throughput a "Listos"
                      </p>
                      <p className="mt-1 text-xs text-white/60">
                        Más piezas listas = más capacidad de leads sin fatiga, y ROI más estable.
                      </p>
                    </div>
                    <div className="rounded-xl border border-white/10 bg-black/20 p-3">
                      <p className="text-xs font-semibold text-white/80">
                        Palanca 2: mejorar performance (CPL y close rate)
                      </p>
                      <p className="mt-1 text-xs text-white/60">
                        Creatividades y oferta impactan CPL; nurturing y ventas impactan conversión.
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            {/* Footer note */}
            <div className="mt-4 flex flex-col gap-2 rounded-2xl border border-white/10 bg-black/20 p-4 text-xs text-white/60 md:flex-row md:items-center md:justify-between">
              <div className="flex items-center gap-2">
                <CheckCircle2 className="h-4 w-4 text-emerald-300" />
                <span>
                  Modelo orientado a narrativa de inversión: supply (ClickUp) → escala Ads → leads/ventas.
                </span>
              </div>
              <div className="flex items-center gap-2">
                <Timer className="h-4 w-4 text-amber-200" />
                <span>
                  Consejo: conecta esto a datos reales (ClickUp API + CRM) para calibrar CPL y conversión.
                </span>
              </div>
            </div>
          </SectionCard>
        </div>

        {/* Bottom tiny "ClickUp alignment" */}
        <div className="mt-6 rounded-2xl border border-white/10 bg-slate-950/40 p-5">
          <div className="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
            <div className="flex items-center gap-3">
              <div className="rounded-xl border border-white/10 bg-white/5 p-2">
                <LayoutDashboard className="h-5 w-5 text-white/90" />
              </div>
              <div>
                <p className="text-sm font-semibold">Alineación con ClickUp: "Abril Contenido"</p>
                <p className="mt-1 text-xs text-white/60">
                  Estados considerados: Grabación, Por Revisión, Listos por calendarizar, Tarjetas Completadas.
                </p>
              </div>
            </div>

            <div className="flex flex-wrap items-center gap-2">
              <span className="rounded-full border border-white/10 bg-black/30 px-3 py-1 text-xs text-white/70">
                80 tareas/mes (simulado)
              </span>
              <span className="rounded-full border border-white/10 bg-black/30 px-3 py-1 text-xs text-white/70">
                Dark mode + vibrante
              </span>
              <span className="rounded-full border border-white/10 bg-black/30 px-3 py-1 text-xs text-white/70">
                Recharts + Tailwind
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}
