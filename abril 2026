                    </div>
                    <span class="rounded-full border border-white/10 bg-black/30 px-3 py-1 text-xs text-white/70 h-fit" id="tag-prod">Capacidad alta</span>
                </div>
            </div>

            <div class="glass-card">
                <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-amber-500/20 via-rose-500/10 to-violet-500/15"></div>
                <div class="relative flex justify-between gap-4">
                    <div class="flex items-start gap-3">
                        <div class="rounded-xl border border-white/10 bg-white/5 p-2"><i data-lucide="activity" class="h-5 w-5 text-white/90"></i></div>
                        <div>
                            <div class="flex items-center gap-2">
                                <p class="text-sm text-white/70">Semáforo del tablero</p>
                                <span class="inline-flex items-center gap-1 rounded-full border border-white/10 bg-black/30 px-2 py-0.5 text-xs text-white/70">
                                    <i data-lucide="circle-dot" class="h-3 w-3 text-emerald-400" id="dot-status"></i>
                                    <span id="txt-status">Saludable</span>
                                </span>
                            </div>
                            <p class="mt-1 text-2xl font-semibold tracking-tight text-white" id="kpi-status-main">Saludable</p>
                            <p class="mt-1 text-xs text-white/60">Señal operativa en base a presión de "Por Revisión".</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-4 lg:grid-cols-3 mb-6">
            <div class="glass-card lg:col-span-2">
                <div class="mb-4 flex items-center gap-2">
                    <div class="rounded-xl border border-white/10 bg-white/5 p-2"><i data-lucide="target" class="h-5 w-5 text-white/90"></i></div>
                    <div>
                        <h2 class="text-base font-semibold text-white">Embudo de Producción (ClickUp)</h2>
                        <p class="mt-0.5 text-xs text-white/60">Grabación → Por Revisión → Listos por calendarizar → Completadas</p>
                    </div>
                </div>
                
                <div class="mb-4 grid grid-cols-2 gap-3 sm:grid-cols-4">
                    <div class="rounded-2xl border border-white/10 bg-black/20 p-3">
                        <div class="flex items-center justify-between"><p class="text-xs text-white/70">Grabación</p><span class="h-2.5 w-2.5 rounded-full bg-cyan-400"></span></div>
                        <p class="mt-2 text-xl font-semibold" id="val-grab">18</p>
                        <p class="mt-1 text-xs text-white/50">23% del total</p>
                    </div>
                    <div class="rounded-2xl border border-white/10 bg-black/20 p-3">
                        <div class="flex items-center justify-between"><p class="text-xs text-white/70">Por Revisión</p><span class="h-2.5 w-2.5 rounded-full bg-amber-400"></span></div>
                        <p class="mt-2 text-xl font-semibold" id="val-rev">15</p>
                        <p class="mt-1 text-xs text-white/50">19% del total</p>
                    </div>
                    <div class="rounded-2xl border border-white/10 bg-black/20 p-3">
                        <div class="flex items-center justify-between"><p class="text-xs text-white/70">Listos</p><span class="h-2.5 w-2.5 rounded-full bg-violet-400"></span></div>
                        <p class="mt-2 text-xl font-semibold" id="val-listos">17</p>
                        <p class="mt-1 text-xs text-white/50">21% del total</p>
                    </div>
                    <div class="rounded-2xl border border-white/10 bg-black/20 p-3">
                        <div class="flex items-center justify-between"><p class="text-xs text-white/70">Completadas</p><span class="h-2.5 w-2.5 rounded-full bg-emerald-400"></span></div>
                        <p class="mt-2 text-xl font-semibold" id="val-comp">30</p>
                        <p class="mt-1 text-xs text-white/50">38% del total</p>
                    </div>
                </div>

                <div id="chart-funnel" style="height: 300px; width: 100%;"></div>
            </div>

            <div class="glass-card lg:col-span-1">
                <div class="mb-4 flex items-center gap-2">
                    <div class="rounded-xl border border-white/10 bg-white/5 p-2"><i data-lucide="alert-triangle" class="h-5 w-5 text-white/90"></i></div>
                    <div>
                        <h2 class="text-base font-semibold text-white">Alertas y cuellos de botella</h2>
                        <p class="mt-0.5 text-xs text-white/60">Reglas automáticas para acelerar producción</p>
                    </div>
                </div>
                
                <div class="space-y-3" id="alerts-container">
                    </div>

                <div class="mt-4 rounded-2xl border border-white/10 bg-black/20 p-4">
                    <p class="text-xs text-white/60">Recomendación PM rápida:</p>
                    <ul class="mt-2 list-disc space-y-1 pl-4 text-xs text-white/65">
                        <li>Define SLA de revisión (ej: 24h) y un “revisor dueño” por día.</li>
                        <li>Checklist de criterios de “Listo” para reducir iteraciones.</li>
                        <li>Bloques diarios de 30-45 min para limpiar cola de revisión.</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-4 lg:grid-cols-3 mb-6">
            <div class="glass-card lg:col-span-2">
                <div class="mb-4 flex items-center gap-2">
                    <div class="rounded-xl border border-white/10 bg-white/5 p-2"><i data-lucide="arrow-up-right" class="h-5 w-5 text-white/90"></i></div>
                    <div>
                        <h2 class="text-base font-semibold text-white">Correlación Marketing (output) vs Ventas/Leads</h2>
                        <p class="mt-0.5 text-xs text-white/60">Supply de contenido (listos+completados) impulsa leads y ventas</p>
                    </div>
                </div>
                <div id="chart-weekly" style="height: 320px; width: 100%;"></div>
            </div>

            <div class="glass-card lg:col-span-1">
                <div class="mb-4 flex items-center gap-2">
                    <div class="rounded-xl border border-white/10 bg-white/5 p-2"><i data-lucide="trending-up" class="h-5 w-5 text-white/90"></i></div>
                    <div>
                        <h2 class="text-base font-semibold text-white">Relación Supply → Leads</h2>
                        <p class="mt-0.5 text-xs text-white/60">Dispersión semanal simulada</p>
                    </div>
                </div>
                <div id="chart-scatter" style="height: 320px; width: 100%;"></div>
            </div>
        </div>

        <div class="glass-card mb-6">
            <div class="mb-4 flex items-center gap-2">
                <div class="rounded-xl border border-white/10 bg-white/5 p-2"><i data-lucide="sliders-horizontal" class="h-5 w-5 text-white/90"></i></div>
                <div>
                    <h2 class="text-base font-semibold text-white">Simulador de Presupuesto (Ads) y ROI proyectado</h2>
                    <p class="mt-0.5 text-xs text-white/60">Mueve el presupuesto y observa el impacto limitado por contenido</p>
                </div>
            </div>

            <div class="grid grid-cols-1 gap-4 lg:grid-cols-3">
                <div class="rounded-2xl border border-white/10 bg-black/20 p-5">
                    <div class="flex items-center justify-between mb-4">
                        <p class="text-sm font-semibold text-white">Presupuesto mensual</p>
                        <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-white/70" id="lbl-presupuesto">$18,000</span>
                    </div>
                    
                    <input type="range" id="sim-budget" min="5000" max="50000" step="500" value="18000">
                    <div class="mt-2 flex items-center justify-between text-xs text-white/55">
                        <span>$5,000</span><span>$50,000</span>
                    </div>

                    <div class="mt-5 space-y-3">
                        <div class="flex items-center justify-between rounded-xl border border-white/10 bg-white/5 px-3 py-2">
                            <span class="text-xs text-white/70">Contenido listo</span>
                            <span class="text-xs font-semibold" id="lbl-ready">47</span>
                        </div>
                        <div class="flex items-center justify-between rounded-xl border border-white/10 bg-white/5 px-3 py-2">
                            <span class="text-xs text-white/70">Capacidad leads (por contenido)</span>
                            <span class="text-xs font-semibold" id="lbl-cap">5,640</span>
                        </div>
                    </div>

                    <div id="sim-alert-box" class="mt-4 rounded-2xl border p-4 border-emerald-500/30 bg-emerald-500/10 text-emerald-200">
                        <div class="flex items-start gap-3">
                            <i data-lucide="check-circle-2" class="h-5 w-5 mt-0.5" id="sim-alert-icon"></i>
                            <div>
                                <p class="text-sm font-semibold" id="sim-alert-title">Escala soportada por contenido</p>
                                <p class="mt-1 text-xs opacity-90" id="sim-alert-desc">El presupuesto está dentro del límite operativo.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="lg:col-span-2 rounded-2xl border border-white/10 bg-black/20 p-5">
                    <div class="grid grid-cols-1 gap-3 md:grid-cols-4 mb-4">
                        <div class="rounded-2xl border border-white/10 bg-slate-950/40 p-4">
                            <p class="text-xs text-white/60">CPL estimado</p>
                            <p class="mt-1 text-lg font-semibold" id="res-cpl">$14.50</p>
                            <p class="mt-1 text-xs text-white/55">Subida por saturación</p>
                        </div>
                        <div class="rounded-2xl border border-white/10 bg-slate-950/40 p-4">
                            <p class="text-xs text-white/60">Leads</p>
                            <p class="mt-1 text-lg font-semibold" id="res-leads">1,241</p>
                        </div>
                        <div class="rounded-2xl border border-white/10 bg-slate-950/40 p-4">
                            <p class="text-xs text-white/60">Ventas</p>
                            <p class="mt-1 text-lg font-semibold" id="res-sales">68</p>
                        </div>
                        <div class="rounded-2xl border border-white/10 bg-slate-950/40 p-4">
                            <p class="text-xs text-white/60">Revenue</p>
                            <p class="mt-1 text-lg font-semibold" id="res-rev">$17,000</p>
                        </div>
                    </div>

                    <div class="rounded-2xl border border-white/10 bg-slate-950/40 p-4 mb-3">
                        <div class="flex items-center justify-between gap-3">
                            <div class="flex items-center gap-2">
                                <div class="rounded-xl border border-white/10 bg-white/5 p-2"><i data-lucide="badge-dollar-sign" class="h-5 w-5 text-emerald-300"></i></div>
                                <div>
                                    <p class="text-xs text-white/60">ROI proyectado</p>
                                    <p class="text-xl font-semibold text-emerald-300" id="res-roi">40%</p>
                                </div>
                            </div>
                            <div class="rounded-full border border-white/10 bg-black/30 px-3 py-1 text-xs text-white/70" id="tag-roi">Caso fuerte</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Formateadores
        const fmtInt = (n) => new Intl.NumberFormat("es-ES").format(Math.round(n));
        const fmtPct = (n) => new Intl.NumberFormat("es-ES", { style: "percent", maximumFractionDigits: 0 }).format(n);
        const fmtMoney = (n) => new Intl.NumberFormat("en-US", { style: "currency", currency: "USD", maximumFractionDigits: 0 }).format(n);

        // Variables base (ClickUp Simulador)
        const total = 80;
        const grabacion = 18;
        const revision = 15;
        const listos = 17;
        const completadas = 30;
        const readyToRun = listos + completadas; // 47
        const productivity = completadas / total;

        // ROI Simulator Params
        const avgOrderValue = 250;
        const closeRate = 0.055;
        const cplBase = 7.5;

        // Inicialización y cálculos
        window.onload = () => {
            // Inicializar Iconos Lucide
            lucide.createIcons();

            // Setup estático
            document.getElementById('lbl-ready').innerText = readyToRun;
            
            // Renderizar gráficos
            renderFunnel();
            renderWeekly();
            
            // Generar alertas
            generateAlerts();

            // Atar slider
            document.getElementById('sim-budget').addEventListener('input', calculateROI);
            
            // Calcular primera vez
            calculateROI();
        };

        function calculateROI() {
            const budget = parseFloat(document.getElementById('sim-budget').value);
            document.getElementById('lbl-presupuesto').innerText = fmtMoney(budget);

            const leadsCapacity = readyToRun * 120; // 47 * 120 = 5640
            document.getElementById('lbl-cap').innerText = fmtInt(leadsCapacity);

            // cpl = cplBase * (1 + (budget / 20000)^0.55)
            const cpl = cplBase * (1 + Math.pow(budget / 20000, 0.55));
            const leadsByBudget = budget / cpl;
            const leads = Math.round(Math.min(leadsByBudget, leadsCapacity));
            const sales = Math.round(leads * closeRate);
            const revenue = sales * avgOrderValue;
            const roi = budget > 0 ? (revenue - budget) / budget : 0;
            const isConstrained = leadsByBudget > leadsCapacity;

            // Actualizar textos
            document.getElementById('res-cpl').innerText = fmtMoney(cpl);
            document.getElementById('res-leads').innerText = fmtInt(leads);
            document.getElementById('res-sales').innerText = fmtInt(sales);
            document.getElementById('res-rev').innerText = fmtMoney(revenue);
            
            const roiEl = document.getElementById('res-roi');
            const tagRoi = document.getElementById('tag-roi');
            roiEl.innerText = fmtPct(roi);
            
            if(roi >= 0.4) { roiEl.className = "text-xl font-semibold text-emerald-300"; tagRoi.innerText = "Caso fuerte para inversión"; }
            else if(roi >= 0.15) { roiEl.className = "text-xl font-semibold text-amber-200"; tagRoi.innerText = "Razonable, optimiza ads"; }
            else { roiEl.className = "text-xl font-semibold text-rose-300"; tagRoi.innerText = "Requiere ajustes"; }

            // Alerta Box
            const alertBox = document.getElementById('sim-alert-box');
            const alertIcon = document.getElementById('sim-alert-icon');
            const alertTitle = document.getElementById('sim-alert-title');
            const alertDesc = document.getElementById('sim-alert-desc');

            if (isConstrained) {
                alertBox.className = "mt-4 rounded-2xl border p-4 border-amber-500/30 bg-amber-500/10 text-amber-200";
                alertTitle.innerText = "Limitado por inventario creativo";
                alertDesc.innerText = "El presupuesto es alto, pero el rendimiento se frena por falta de contenido listo. Acelera ClickUp.";
                lucide.createIcons({icons: { AlertTriangle }, nameAttr: 'data-lucide', attrs: {class: "h-5 w-5 mt-0.5"} });
            } else {
                alertBox.className = "mt-4 rounded-2xl border p-4 border-emerald-500/30 bg-emerald-500/10 text-emerald-200";
                alertTitle.innerText = "Escala soportada por contenido";
                alertDesc.innerText = "El presupuesto está dentro del límite operativo de contenido listo.";
                // Reset to check
            }
        }

        function generateAlerts() {
            const container = document.getElementById('alerts-container');
            let html = '';

            // Revisión
            if (revision >= 15) {
                html += `<div class="rounded-2xl border p-4 border-rose-500/30 bg-rose-500/10 text-rose-200"><div class="flex items-start gap-3"><i data-lucide="alert-triangle" class="mt-0.5 h-5 w-5"></i><div><p class="text-sm font-semibold">Alerta: ${revision} tarjetas estancadas en "Por Revisión"</p><p class="mt-1 text-xs opacity-90">Riesgo directo para escalar Ads: sin aprobación, no hay contenido. Prioriza revisiones.</p></div></div></div>`;
            } else {
                html += `<div class="rounded-2xl border p-4 border-emerald-500/30 bg-emerald-500/10 text-emerald-200"><div class="flex items-start gap-3"><i data-lucide="check-circle-2" class="mt-0.5 h-5 w-5"></i><div><p class="text-sm font-semibold">Revisión bajo control</p></div></div></div>`;
            }

            // Supply
            if (readyToRun >= 40) {
                html += `<div class="rounded-2xl border p-4 border-emerald-500/30 bg-emerald-500/10 text-emerald-200"><div class="flex items-start gap-3"><i data-lucide="check-circle-2" class="mt-0.5 h-5 w-5"></i><div><p class="text-sm font-semibold">Capacidad alta: ${readyToRun} piezas listas</p><p class="mt-1 text-xs opacity-90">Argumento fuerte para invertir: hay inventario para sostener pruebas A/B.</p></div></div></div>`;
            }

            container.innerHTML = html;
            lucide.createIcons();
        }

        function renderFunnel() {
            const data = [{
                x: ['Grabación', 'Por Revisión', 'Listos', 'Completadas'],
                y: [grabacion, revision, listos, completadas],
                type: 'bar',
                marker: { color: ['#22d3ee', '#fbbf24', '#a78bfa', '#34d399'], width: 1 },
                text: [grabacion, revision, listos, completadas],
                textposition: 'auto',
            }];

            const layout = {
                paper_bgcolor: 'rgba(0,0,0,0)',
                plot_bgcolor: 'rgba(0,0,0,0)',
                font: { color: '#FAFAFA' },
                margin: { l: 20, r: 20, t: 20, b: 30 },
                xaxis: { tickfont: { size: 11 }, gridcolor: 'rgba(255,255,255,0.05)' },
                yaxis: { visible: false, gridcolor: 'rgba(255,255,255,0.05)' },
            };

            Plotly.newPlot('chart-funnel', data, layout, {responsive: true, displayModeBar: false});
        }

        function renderWeekly() {
            // Simulando la data de 4 semanas
            const dist = [0.20, 0.24, 0.26, 0.30];
            const weeks = ['Sem 1', 'Sem 2', 'Sem 3', 'Sem 4'];
            let supplyArr = [], leadsArr = [], salesArr = [];
            let baselineLeads = 320;

            for(let i=0; i<4; i++) {
                let comp = Math.round(completadas * dist[i]);
                let rea = Math.round(listos * dist[i]);
                let sup = comp + rea;
                let increm = (sup * 9) + (comp * 4);
                let leads = Math.round((baselineLeads/4) + increm);
                let sales = Math.round(leads * 0.06);

                supplyArr.push(sup);
                leadsArr.push(leads);
                salesArr.push(sales);
            }

            const trace1 = { x: weeks, y: supplyArr, name: 'Supply (Mkt)', type: 'scatter', mode: 'lines', fill: 'tozeroy', line: {color: '#a78bfa'}, fillcolor: 'rgba(167, 139, 250, 0.15)' };
            const trace2 = { x: weeks, y: leadsArr, name: 'Leads', type: 'scatter', mode: 'lines+markers', line: {color: '#22d3ee', width: 3}, yaxis: 'y2' };
            const trace3 = { x: weeks, y: salesArr, name: 'Ventas', type: 'scatter', mode: 'lines+markers', line: {color: '#34d399', width: 3}, yaxis: 'y2' };

            const layoutComposed = {
                paper_bgcolor: 'rgba(0,0,0,0)',
                plot_bgcolor: 'rgba(0,0,0,0)',
                font: { color: '#FAFAFA' },
                margin: { l: 30, r: 40, t: 20, b: 30 },
                legend: { orientation: 'h', y: -0.1 },
                xaxis: { gridcolor: 'rgba(255,255,255,0.05)' },
                yaxis: { title: 'Supply', gridcolor: 'rgba(255,255,255,0.05)' },
                yaxis2: { title: 'Leads/Sales', overlaying: 'y', side: 'right', showgrid: false }
            };
            Plotly.newPlot('chart-weekly', [trace1, trace2, trace3], layoutComposed, {responsive: true, displayModeBar: false});

            const traceScatter = { x: supplyArr, y: leadsArr, mode: 'markers', type: 'scatter', marker: { size: 12, color: '#22d3ee' } };
            const layoutScatter = {
                paper_bgcolor: 'rgba(0,0,0,0)',
                plot_bgcolor: 'rgba(0,0,0,0)',
                font: { color: '#FAFAFA' },
                margin: { l: 40, r: 20, t: 20, b: 40 },
                xaxis: { title: 'Supply (Piezas Listas)', gridcolor: 'rgba(255,255,255,0.05)' },
                yaxis: { title: 'Leads Generados', gridcolor: 'rgba(255,255,255,0.05)' }
            };
            Plotly.newPlot('chart-scatter', [traceScatter], layoutScatter, {responsive: true, displayModeBar: false});
        }
    </script>
</body>
